#!/usr/bin/env bash
# Wire this checkout into the devcontainer's baked-in Home Assistant install.
#
# The devcontainer's base image (see .devcontainer/devcontainer.json) is the
# official homeassistant/home-assistant image, pinned to a dev-branch
# snapshot. Unlike a generic Python devcontainer, it already bundles HA core,
# the frontend, and every native/runtime dependency default_config needs
# (ffmpeg, go2rtc, PyTurboJPEG, pymicro-vad, pyspeex-noise, aioesphomeapi,
# bleak, hassil, home-assistant-intents) — so there's nothing else to fetch
# here beyond the dev-only tools (ruff, pytest-asyncio) the runtime image
# doesn't ship.
set -euo pipefail

cd "$(dirname "$0")/.."

pip3 install --no-cache-dir ruff pytest-asyncio

mkdir -p config
if [ ! -f config/configuration.yaml ]; then
  cat > config/configuration.yaml <<'YAML'
# kakao_map devcontainer configuration.
homeassistant:
  name: kakao_map Dev
  latitude: 37.5665
  longitude: 126.9780
  elevation: 0
  unit_system: metric
  time_zone: Asia/Seoul
  external_url: "http://localhost:8123"
  internal_url: "http://localhost:8123"

default_config:

http:
  server_port: 8123

logger:
  default: info
  logs:
    custom_components.kakao_map: debug
YAML
fi

# Symlink the integration into HA's config dir so edits hot-reload.
mkdir -p config/custom_components
ln -sfn "$PWD/custom_components/kakao_map" config/custom_components/kakao_map

echo "Setup complete."
echo "  scripts/develop  → run HA from this checkout (port 8123)"
echo "  scripts/test     → run ruff + pytest"
