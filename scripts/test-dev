#!/usr/bin/env bash
# Run the test suite against a pinned home-assistant/core `dev`-branch commit,
# using the vendored harness in tests/vendor/ instead of
# pytest-homeassistant-custom-component (phacc breaks against `dev` — see
# tasks/plan.md T13 for why). Restores the stable pip-installed homeassistant
# afterwards so `scripts/test` keeps working normally.
#
# Delete this script (and tests/vendor/) once phacc ships a release tracking
# HA > 2026.7.2 — check `pip show pytest-homeassistant-custom-component`'s
# `ha_version` file / Requires line, then go back to plain `scripts/test`.
set -euo pipefail

cd "$(dirname "$0")/.."

# Update when re-pinning to a newer dev snapshot (and refresh tests/vendor/
# from the same commit — see tests/vendor/__init__.py).
DEV_SHA=9cd694008baf1222fc3815f9c0d9303dc583c46f
DEV_CHECKOUT=/opt/ha-core-dev
# Read phacc's exact required homeassistant version (not our floor pin) so
# EXIT restores to a version phacc actually supports.
STABLE_PIN=$(python3 -c "
import importlib.metadata as m
for r in m.requires('pytest-homeassistant-custom-component') or []:
    if r.startswith('homeassistant=='):
        print(r.split('==')[1])
        break
")

if [ ! -d "$DEV_CHECKOUT/.git" ]; then
  echo "── cloning home-assistant/core @ $DEV_SHA ──────────"
  mkdir -p "$DEV_CHECKOUT"
  git -C "$DEV_CHECKOUT" init -q
  git -C "$DEV_CHECKOUT" remote add origin https://github.com/home-assistant/core.git
  git -C "$DEV_CHECKOUT" fetch --depth 1 origin "$DEV_SHA"
  git -C "$DEV_CHECKOUT" checkout -q FETCH_HEAD
fi

echo "── installing dev-branch homeassistant ($DEV_SHA) ──"
pip install --no-deps -e "$DEV_CHECKOUT"

echo "── ruff ────────────────────────────────────────────"
ruff check .

echo "── pytest (phacc plugin disabled) ──────────────────"
trap 'echo "── restoring homeassistant==$STABLE_PIN ────────────"; pip install --no-deps "homeassistant==$STABLE_PIN"' EXIT
pytest -p no:homeassistant "$@"
